<Window x:Class="ScreenToGifTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GIF 錄製工具"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Icon="/02.ico">
	<StackPanel Margin="20">
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
			<Button x:Name="btnSelectArea" Content="選擇區域" Width="90" Height="35" Margin="5" Click="BtnSelectArea_Click"/>
			<Button x:Name="btnStart" Content="開始錄製" Width="90" Height="35" Margin="5" IsEnabled="False" Click="BtnStart_Click"/>
			<Button x:Name="btnStop" Content="停止錄製" Width="90" Height="35" Margin="5" IsEnabled="False" Click="BtnStop_Click"/>
		</StackPanel>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
			<TextBlock Text="輸出畫質：" VerticalAlignment="Center" FontSize="14"/>
			<ComboBox x:Name="cbQuality" Width="120" Margin="10,0,0,0" SelectedIndex="1">
				<ComboBoxItem Content="低畫質 (30fps)"/>
				<ComboBoxItem Content="高畫質 (60fps)"/>
			</ComboBox>
		</StackPanel>

		<Label x:Name="lblStatus" Content="準備就緒" HorizontalAlignment="Center" Margin="0,10,0,0"/>

		<ProgressBar x:Name="pbProcessing" IsIndeterminate="True" Height="15" Margin="0,5,0,0" Visibility="Collapsed"/>

	</StackPanel>
</Window>